{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Controller support mod that provides comprehensive gamepad functionality with configurable button mappings and real-time remapping via HTTP API.",
  "authors": [
    "verotek",
    "voltaccept"
  ],
  "contact": {
    "issues": "https://github.com/VoltacceptYT/AnalogAPI/issues",
    "sources": "https://github.com/VoltacceptYT/AnalogAPI"
  },
  "license": "GPL-2.0-or-later",
  "icon": "logo.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.voltaccept.AnalogAPI.AnalogApiMod"
    ]
  },
  "mixins": [
    "analog_api.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "${minecraft}",
    "fabric-api": "*",
    "libanalog": "*"
  }
}
